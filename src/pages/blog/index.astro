---
export const prerender = true;
import Layout from '../../layouts/Layout.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog'))
  .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime());

const categories = [...new Set(posts.map(p => p.data.category))];
---

<Layout title="Insights — Clarence Dyer" description="Practical insights on AI systems, automation, and building businesses with technology.">
  <Nav />

  <main style="padding-top: 72px;">
    <section class="blog-hero">
      <div class="container">
        <div class="section-label">Insights & Writing</div>
        <h1 class="section-title">Thinking Out Loud on <span class="gradient-text">AI & Systems</span></h1>
        <p class="section-subtitle">
          Practical insights, frameworks, and deep-dives on building AI systems,
          automating businesses, and creating leverage through technology.
        </p>
      </div>
    </section>

    <section class="blog-listing">
      <div class="container">
        <div class="posts-grid">
          {posts.map(post => (
            <a href={`/blog/${post.slug}`} class="blog-card-full">
              <div class="blog-meta">
                <span class="blog-category">{post.data.category.replace(/-/g,' ')}</span>
                <span class="blog-date">{post.data.date}</span>
                {post.data.readTime && <span class="blog-read-time">· {post.data.readTime}</span>}
                {post.data.featured && <span class="blog-featured">★ Featured</span>}
              </div>
              <h2 class="blog-title">{post.data.title}</h2>
              <p class="blog-excerpt">{post.data.excerpt}</p>
              <span class="blog-link">Read Article →</span>
            </a>
          ))}
        </div>

        {posts.length === 0 && (
          <div class="empty-state">
            <div class="empty-icon">✍️</div>
            <h3>New insights coming soon</h3>
            <p>Check back soon for articles on AI systems, automation, and building with technology.</p>
          </div>
        )}
      </div>
    </section>
  </main>

  <Footer />
</Layout>

<style>
  .blog-hero {
    padding: 80px 0 48px;
    text-align: center;
    background: radial-gradient(ellipse 60% 40% at 50% 0%, rgba(249,115,22,0.08) 0%, transparent 70%);
  }

  .blog-listing { padding: 48px 0 96px; }

  .posts-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 24px;
  }

  @media (min-width: 768px) {
    .posts-grid { grid-template-columns: repeat(2, 1fr); }
  }

  @media (min-width: 1100px) {
    .posts-grid { grid-template-columns: repeat(3, 1fr); }
  }

  .blog-card-full {
    background: var(--bg-card);
    border: 1px solid var(--border-card);
    border-radius: var(--radius-lg);
    padding: 28px;
    display: flex;
    flex-direction: column;
    gap: 12px;
    transition: border-color 0.2s, transform 0.2s;
  }

  .blog-card-full:hover {
    border-color: rgba(249,115,22,0.3);
    transform: translateY(-4px);
  }

  .blog-meta {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    align-items: center;
  }

  .blog-category {
    font-size: 0.68rem;
    font-weight: 700;
    text-transform: capitalize;
    color: var(--accent-orange);
    background: rgba(249,115,22,0.08);
    border-radius: 100px;
    padding: 2px 10px;
  }

  .blog-date, .blog-read-time { font-size: 0.72rem; color: var(--text-muted); }

  .blog-featured {
    font-size: 0.68rem;
    color: #F59E0B;
    background: rgba(245,158,11,0.1);
    border-radius: 100px;
    padding: 2px 10px;
  }

  .blog-title {
    font-size: 1.05rem;
    font-weight: 700;
    line-height: 1.4;
  }

  .blog-excerpt {
    font-size: 0.85rem;
    color: var(--text-secondary);
    line-height: 1.7;
    flex: 1;
  }

  .blog-link {
    font-size: 0.82rem;
    font-weight: 600;
    color: var(--accent-orange);
  }

  .empty-state {
    text-align: center;
    padding: 80px 0;
    color: var(--text-secondary);
  }

  .empty-icon { font-size: 3rem; margin-bottom: 16px; }
  .empty-state h3 { font-size: 1.2rem; margin-bottom: 8px; color: var(--text-primary); }
</style>
